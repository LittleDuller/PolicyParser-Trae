# ------------------------------
# 监控与追踪配置
# ------------------------------

# LangSmith配置信息
# 如果为空或为 false，不启用 LangSmith 监控
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=policy-parser

# ------------------------------
# 模型配置
# ------------------------------

# OpenAI
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# DashScope / 通义千问
DASHSCOPE_API_BASE=
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=Qwen/Qwen3.5-122B-A10B

# ------------------------------
# 数据库配置 (MySQL)
# ------------------------------

# 数据库连接信息
DB_HOST=192.168.0.200
DB_PORT=3306
DB_USER=idsp_dev
DB_PASSWORD=your_password_here
DB_NAME=idsp_dev

# 数据库连接池配置（可选，使用默认值即可）
# DB_ECHO=false
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=3600